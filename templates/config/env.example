# Copy this file to <workdir>/sites/<site-id>/site.env and fill real values there.
# Do not put real secrets in this example file.

VPS_HOST="203.0.113.10"
SSH_USER="ubuntu"
SSH_KEY_PATH="/path/to/key.pem"
SSH_PORT="22"

# Root access bootstrap.
# ROOT_PASSWORD must be a high-entropy password in real configs.
# ROOT_PASSWORD_SOURCE can be manual, 1password, op, or generated.
# ENABLE_ROOT_PASSWORD_LOGIN defaults to false. Setting a root password does not
# mean SSH root password login should be enabled.
ROOT_PASSWORD=""
ROOT_PASSWORD_SOURCE="manual"
ENABLE_ROOT_PASSWORD_LOGIN="false"

DOMAIN="panel.example.com"

SUI_INITIAL_ADMIN_USERNAME=""
SUI_INITIAL_ADMIN_PASSWORD=""
SUI_INITIAL_ADMIN_SOURCE="install-output"

WEB_PORT="2095"
WEB_PATH="/replace-with-random-panel-path/"
SUB_PORT="2096"
SUB_PATH="/replace-with-random-sub-path/"

SSL_HTTP_PORT="80"
SSL_CERT_FULLCHAIN_PATH="/root/cert/panel.example.com/fullchain.pem"
SSL_CERT_KEY_PATH="/root/cert/panel.example.com/privkey.pem"
SSL_CERT_SOURCE="s-ui-acme"

# Certificate auto-renew control (Phase 6).
# Leave *_DAYS empty to auto-calculate from the actual certificate lifetime.
CERT_AUTORENEW_ENABLED="true"
CERT_RENEW_METHOD="acme.sh"
CERT_RENEW_BEFORE_DAYS=""
CERT_RENEW_URGENT_BEFORE_DAYS=""
CERT_MAX_CONSECUTIVE_FAILURES="5"
CERT_RETRY_BACKOFF_MINUTES="60"
CERT_SUPERVISOR_INTERVAL="12h"
CERT_VERIFY_EXTRA_PORTS="41101"
CERT_RELOAD_STRATEGY="restart_s_ui"

AWS_SECURITY_GROUP_REQUIRED_TCP_PORTS="22,80,2095,2096,443,41101"
AWS_SECURITY_GROUP_REQUIRED_UDP_PORTS="59501,8443"
UFW_EXPECTED_STATUS="inactive"

TLS_REALITY_TAG="reality"
TLS_REALITY_HANDSHAKE_SERVER="aws.amazon.com"
TLS_REALITY_HANDSHAKE_PORT="443"
TLS_REALITY_UTLS_FINGERPRINT="chrome"
TLS_REALITY_PRIVATE_KEY=""
TLS_REALITY_PUBLIC_KEY=""
TLS_REALITY_SHORT_ID=""

TLS_STANDARD_TAG="tls"
TLS_STANDARD_SERVER_NAME="panel.example.com"
TLS_STANDARD_ALPN="h3,h2,http/1.1"
TLS_STANDARD_ALLOW_INSECURE="true"

TLS_HYSTERIA2_TAG="hy2-tls"
TLS_HYSTERIA2_SERVER_NAME="panel.example.com"
TLS_HYSTERIA2_ALPN="h3"
TLS_HYSTERIA2_ALLOW_INSECURE="true"

# Outbound mode:
# - direct: use the VPS default public IP; leave proxy fields empty.
# - socks: create a residential SOCKS outbound and route final traffic to it.
# - empty: auto-detect socks when OUTBOUND_SERVER and OUTBOUND_PORT are filled; otherwise direct.
OUTBOUND_MODE=""
OUTBOUND_TAG="socks-residential"
OUTBOUND_TYPE="socks"
OUTBOUND_SERVER=""
OUTBOUND_PORT=""
OUTBOUND_USERNAME=""
OUTBOUND_PASSWORD=""

INBOUND_VLESS_TAG="vless-reality"
INBOUND_VLESS_PORT="443"
INBOUND_VLESS_SNI="aws.amazon.com"
INBOUND_VLESS_TLS_TAG="reality"

INBOUND_TUIC_TAG="tuic-59501"
INBOUND_TUIC_PORT="59501"
INBOUND_TUIC_TLS_TAG="tls"

INBOUND_HYSTERIA2_TAG="hysteria2"
INBOUND_HYSTERIA2_PORT="8443"
INBOUND_HYSTERIA2_TLS_TAG="hy2-tls"

INBOUND_TROJAN_TAG="trojan-ws"
INBOUND_TROJAN_PORT="41101"
INBOUND_TROJAN_WS_PATH="/replace-with-random-ws-path"
INBOUND_TROJAN_HOST="aws.amazon.com"
INBOUND_TROJAN_TLS_TAG="tls"

# Client name defaults to SITE_ID. Keep CLIENT_NAME empty unless migrating an
# older site that used a different client name.
CLIENT_NAME=""

# S-UI API automation. Create the first token manually in the S-UI Admin page.
SUI_API_BASE_URL="https://panel.example.com:2095/app"
SUI_API_TOKEN=""
SUI_API_TOKEN_SOURCE="manual"
