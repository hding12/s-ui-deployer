# Copy this file to:
#
#   <workdir>/sites/<site-id>/site.env
#
# This example intentionally contains no real configuration.
# Fill real values only in <workdir>/sites/<site-id>/site.env.

# Unique local name for this EC2 site.
# The primary S-UI client name defaults to SITE_ID.
# Example format: example-us-1, example-eu-1, example-asia-1.
SITE_ID=""

# Public IPv4 address of the VPS / EC2 instance.
# Example format only: 203.0.113.10
VPS_HOST=""

# SSH login user. AWS Ubuntu images usually use ubuntu.
SSH_USER="ubuntu"

# Local SSH private key path.
# The tool will automatically chmod this key to 600 when possible.
# Example format only: /path/to/private-key.pem
SSH_KEY_PATH=""

# SSH port. Keep 22 unless you changed the server SSH daemon.
SSH_PORT="22"

# Root password bootstrap.
# Leave ROOT_PASSWORD empty if you want the tooling workflow to generate
# a 20-character strong password and store it only in your private work config
# or password manager.
ROOT_PASSWORD=""
ROOT_PASSWORD_SOURCE="generated"
ENABLE_ROOT_PASSWORD_LOGIN="false"

# Domain that points to the VPS public IP.
# Before issuing certificates, DNS A record must resolve to VPS_HOST.
# Example format only: panel.example.com
DOMAIN=""

# Initial S-UI administrator fields.
# Leave username empty to keep the username generated by S-UI.
# Leave password empty if you want the tooling workflow to generate
# a 20-character strong password and configure it through automation.
SUI_INITIAL_ADMIN_USERNAME=""
SUI_INITIAL_ADMIN_PASSWORD=""
SUI_INITIAL_ADMIN_SOURCE="install-output"

# Web panel HTTPS settings.
# WEB_PATH must be a long random path and must start/end with /.
WEB_PORT="2095"
WEB_PATH=""

# Subscription HTTPS settings.
# SUB_PATH must be a long random path and must start/end with /.
SUB_PORT="2096"
SUB_PATH=""

# SSL certificate settings.
# AWS Security Group must open TCP 80 before issue-cert.
# S-UI installs certs to /root/cert/<domain>/fullchain.pem and privkey.pem.
SSL_HTTP_PORT="80"
SSL_CERT_FULLCHAIN_PATH=""
SSL_CERT_KEY_PATH=""
SSL_CERT_SOURCE="s-ui-acme"

# Cloud firewall expectation.
# Open TCP: SSH, 80, web panel, subscription, VLESS/Trojan ports.
# Open UDP: TUIC and Hysteria2 ports.
AWS_SECURITY_GROUP_REQUIRED_TCP_PORTS="22,80,2095,2096,443,41101"
AWS_SECURITY_GROUP_REQUIRED_UDP_PORTS="59501,443"
UFW_EXPECTED_STATUS="inactive"

# REALITY TLS template.
# Leave keys empty; plan-apply uses S-UI /apiv2/keypairs?k=reality to generate them.
# SHORT_ID may stay empty unless your chosen client policy requires one.
TLS_REALITY_TAG="reality"
TLS_REALITY_HANDSHAKE_SERVER="aws.amazon.com"
TLS_REALITY_HANDSHAKE_PORT="443"
TLS_REALITY_UTLS_FINGERPRINT="chrome"
TLS_REALITY_PRIVATE_KEY=""
TLS_REALITY_PUBLIC_KEY=""
TLS_REALITY_SHORT_ID=""

# Standard TLS template for TUIC and Trojan WS/TLS.
TLS_STANDARD_TAG="tls"
TLS_STANDARD_SERVER_NAME=""
TLS_STANDARD_ALPN="h3,h2,http/1.1"
TLS_STANDARD_ALLOW_INSECURE="true"

# Hysteria2 TLS template.
# Keep separate from standard TLS to avoid accidental option coupling.
TLS_HYSTERIA2_TAG="hy2-tls"
TLS_HYSTERIA2_SERVER_NAME=""
TLS_HYSTERIA2_ALPN="h3"
TLS_HYSTERIA2_ALLOW_INSECURE="true"

# Outbound mode.
# Use OUTBOUND_MODE="direct" when this site should use the VPS default public IP.
# Use OUTBOUND_MODE="socks" when this site should route through a residential SOCKS proxy.
# Leave empty to auto-detect: filled OUTBOUND_SERVER + OUTBOUND_PORT means socks; otherwise direct.
OUTBOUND_MODE=""

# Residential SOCKS outbound.
# Required only when OUTBOUND_MODE="socks" or when auto-detect should choose socks.
# Leave these fields empty for OUTBOUND_MODE="direct".
OUTBOUND_TAG="socks-residential"
OUTBOUND_TYPE="socks"
OUTBOUND_SERVER=""
OUTBOUND_PORT=""
OUTBOUND_USERNAME=""
OUTBOUND_PASSWORD=""

# VLESS REALITY inbound.
INBOUND_VLESS_TAG="vless-reality"
INBOUND_VLESS_PORT="443"
INBOUND_VLESS_SNI="aws.amazon.com"
INBOUND_VLESS_TLS_TAG="reality"

# TUIC inbound. Security Group must open this UDP port.
INBOUND_TUIC_TAG="tuic-59501"
INBOUND_TUIC_PORT="59501"
INBOUND_TUIC_TLS_TAG="tls"

# Hysteria2 inbound. Security Group must open this UDP port.
# HYSTERIA2_UDP_PORT overrides INBOUND_HYSTERIA2_PORT when present.
INBOUND_HYSTERIA2_TAG="hysteria2"
INBOUND_HYSTERIA2_PORT="8443"
HYSTERIA2_UDP_PORT="443"
INBOUND_HYSTERIA2_TLS_TAG="hy2-tls"

# Trojan WebSocket over TLS inbound.
# Leave path empty to let plan-apply generate a random WebSocket path.
INBOUND_TROJAN_TAG="trojan-ws"
INBOUND_TROJAN_PORT="41101"
INBOUND_TROJAN_WS_PATH=""
INBOUND_TROJAN_HOST="aws.amazon.com"
INBOUND_TROJAN_TLS_TAG="tls"

# Primary client.
# Leave empty in new sites. The tool defaults the primary client name to SITE_ID.
# Use this only when migrating an old site whose client already has another name.
CLIENT_NAME=""

# S-UI API automation.
# Leave token empty before create-api-token.
# The tool writes the generated token back to the private work site.env.
SUI_API_BASE_URL=""
SUI_API_TOKEN=""
SUI_API_TOKEN_SOURCE="generated"

# Local/VPN DNS workaround.
# false allows local API calls to connect even when local VPN DNS resolves the
# domain to a synthetic address. The tool still forces HTTPS to VPS_HOST.
SUI_API_TLS_VERIFY="false"
